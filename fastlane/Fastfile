# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do

  desc "Runs all the tests"
  lane :test do
    gradle(task: "testDebugUnitTest")
  end

  desc "Create a beta version and send it to Firebase"
  lane :beta do

    def get_local_properties(key)
      properties_file = '../local.properties'
      if File.exist?(properties_file)
        File.foreach(properties_file) do |line|
          return line.split('=')[1].strip if line.start_with?(key)
        end
      end
      nil
    end

    firebase_id = get_local_properties("firebase_beta_id")

    gradle(
      task: "assemble",
      build_type: "Debug"
    )

    firebase_app_distribution(
      app: "#{firebase_id}",
      groups: "testers",
      service_credentials_file: "firebase-distribution.json"
    )

  end

  desc "Create a release version and send it to Github"
  lane :release do

#     def get_keystore_properties(key)
#       properties_file = '../keystore.properties'
#       if File.exist?(properties_file)
#         File.foreach(properties_file) do |line|
#           return line.split('=')[1].strip if line.start_with?(key)
#         end
#       end
#       nil
#     end
#
#     firebase_id = get_keystore_properties("firebase_beta_id")
#     storePassword = get_keystore_properties("storePassword")
#     keyPassword = get_keystore_properties("keyPassword")
#     keyAlias = get_keystore_properties("keyAlias")
#     storeFile = get_keystore_properties("storeFile")

    gradle(task: "assemble",build_type: "Release")

    #version_code = get_version_code(gradle_file_path: "app/build.gradle.kts")
    version_name = get_version_name(gradle_file_path: "app/build.gradle.kts")
    tag_name = "v#{version_name}"
    current_branch = "prepare_release"

    if `git tag -l #{tag_name}`.strip.length > 0
      puts "Delete existing tag : #{tag_name}"
      sh("git tag -d #{tag_name}")
    end

    #add_git_tag(tag: tag_name)
    #push_to_git_remote(force: true)
    #sh("git push origin #{current_branch} --tags --force")

    set_github_release(
          repository_name: "ady-kaem/Flux",
          tag_name: tag_name,
          name: "Release #{tag_name}",
          description: (File.read("CHANGELOG.md") rescue "No changelog provided"),
          #commitish: "main",
          commitish: "current_branch",
          upload_assets: ["app/build/outputs/apk/release/app-release.apk"]
        )

  end

end
